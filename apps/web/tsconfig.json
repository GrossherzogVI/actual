{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "target": "es2022",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@finance-os/design-system": [
        "../../packages/design-system/src/index.ts"
      ],
      "@finance-os/domain-kernel": [
        "../../packages/domain-kernel/src/index.ts"
      ]
    },
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
