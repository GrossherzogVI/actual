# SurrealDB credentials — required by docker-compose.level5.yml and schema/apply.sh
# Copy this file to .env and fill in real values before running Docker or the schema scripts.
SURREALDB_USER=your_admin_user
SURREALDB_PASS=your_secure_password

# schema/apply.sh also reads these (defaults are fine for local dev):
# SURREAL_URL=http://localhost:8000
# SURREAL_NS=finance
# SURREAL_DB=main
# SURREAL_USER=<same as SURREALDB_USER above>
# SURREAL_PASS=<same as SURREALDB_PASS above>
